{"name":"String Split and Join","group":"HackerRank - Python - Strings - String Split and Join - Prepare - Python - Strings","url":"https://www.hackerrank.com/challenges/python-string-split-and-join/problem?isFullScreen=true","interactive":false,"memoryLimit":512,"timeLimit":4000,"tests":[{"input":">>> a = \"this is a string\"\n>>> a = a.split(\" \") # a is converted to a list of strings.\n>>> print a\n['this', 'is', 'a', 'string']\n","output":">>> a = \"-\".join(a)\n>>> print a\nthis-is-a-string\n","id":1782384399283},{"input":"this is a string\n","output":"this-is-a-string\n","id":1782384399284}],"testType":"single","input":{"type":"stdin"},"output":{"type":"stdout"},"languages":{"java":{"mainClass":"Main","taskClass":"StringSplitAndJoin"}},"batch":{"id":"de163764-c454-4285-9148-483657a8956e","size":1},"srcPath":"/media/captain-jack-sparrow21/HDD/Code/C++/CPP/HackerRank/Python/String_Split_and_Join.py"}